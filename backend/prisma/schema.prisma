generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Business {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  giro      String   @default("Barbería")
  status    String   @default("ACTIVE") // ACTIVE, SUSPENDED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedSuperAdminId Int?

  users     User[]
  barberos  Barbero[]
  servicios Servicio[]
  citas     Cita[]
  settings  BusinessSetting[]
}

model Barbero {
  id             Int      @id @default(autoincrement())
  nombre         String
  horario_inicio String
  horario_fin    String
  dias_laborales     String   @default("[]")
  horarios_especiales String  @default("{}")
  duracion_cita  Int
  citas          Cita[]
  userId         Int?     @unique
  user           User?    @relation(fields: [userId], references: [id])
  
  businessId     Int      @default(1) // Temporary default for migration
  business       Business @relation(fields: [businessId], references: [id])

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([businessId])
}

model Servicio {
  id        Int      @id @default(autoincrement())
  nombre    String
  duracion  Int
  precio    Decimal   @db.Decimal(10, 2)
  citas     Cita[]
  citasServicios CitaServicio[]
  
  businessId     Int      @default(1)
  business       Business @relation(fields: [businessId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
}

model Cita {
  id          Int      @id @default(autoincrement())
  barbero_id  Int
  servicio_id Int?
  cliente     String
  telefono    String
  fecha       DateTime
  hora        String
  estado      String   @default("confirmada")
  recordatorioEnviado Boolean @default(false)
  duracionTotal Int    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  barbero  Barbero @relation(fields: [barbero_id], references: [id])
  servicio Servicio? @relation(fields: [servicio_id], references: [id])
  servicios CitaServicio[]
  
  businessId     Int      @default(1)
  business       Business @relation(fields: [businessId], references: [id])

  @@index([barbero_id, fecha])
  @@index([businessId])
}

model CitaServicio {
  id         Int      @id @default(autoincrement())
  citaId     Int
  cita       Cita     @relation(fields: [citaId], references: [id], onDelete: Cascade)
  servicioId Int
  servicio   Servicio @relation(fields: [servicioId], references: [id])

  @@unique([citaId, servicioId])
}

model User {
  id             Int      @id @default(autoincrement())
  username       String   @unique
  passwordHash   String
  telefono       String?
  role                UserRole @default(BARBER)
  isMasterSuperAdmin  Boolean  @default(false)
  barbero             Barbero?
  
  businessId     Int      @default(1)
  business       Business @relation(fields: [businessId], references: [id])

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([role])
  @@index([businessId])
}

model BusinessSetting {
  id        Int      @id @default(autoincrement())
  key       String
  value     String
  
  businessId     Int      @default(1)
  business       Business @relation(fields: [businessId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, key]) // Key is unique per business
}

enum UserRole {
  SUPERADMIN
  ADMIN
  BARBER
}
